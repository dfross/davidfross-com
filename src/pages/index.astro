---
import MainLayout from '../layouts/MainLayout.astro'
import { Icon } from 'astro-icon/components'
import { SOCIAL_LINKS } from '../constants'
---

<MainLayout>
	<h1 class="flex flex-col gap-3 text-2xl">
		<span>Hello. I'm David Fross &mdash;</span>
		<span class="text-display">designer &amp; developer.</span>
	</h1>
	<p class="text-2xl font-extralight text-balance">
		Designer and frontend developer focused on accessible, usable interfaces. Decades of frontend judgment, with AI in the workflow.
	</p>
	<nav aria-label="Social links" class="flex gap-6">
		<a
			href={SOCIAL_LINKS.linkedin}
			target="_blank"
			rel="noreferrer"
			class="social-link focus-ring"
			aria-label="Visit David Fross's LinkedIn profile (opens in new tab)">
			<Icon name="linkedin" size="48" aria-hidden="true" />
		</a>
		<a
			href={`mailto:${SOCIAL_LINKS.email}`}
			class="social-link focus-ring"
			aria-label="Send an email to David Fross">
			<Icon name="mailbox" size="48" aria-hidden="true" />
		</a>
	</nav>
</MainLayout>
