---
import MainLayout from '../layouts/MainLayout.astro'
import { Icon } from 'astro-icon/components'
import { SOCIAL_LINKS } from '../constants'
---

<MainLayout PAGE_TITLE="Hello. I am David Fross - Designer & Developer.">
	<h1 class="text-2xl">
		<span class="block">
			<span class="inline-block">Hello.</span>
			<span class="inline-block">I'm David Fross &mdash;</span>
		</span>
		<span class="text-display block pt-3 font-bold">designer &amp; developer.</span>
	</h1>
	<p class="mt-9 text-2xl font-extralight text-balance">
		Maker of digital products and websites that are accessible, a joy to use, and perform exceedingly well.
	</p>
	<div class="mt-9 flex gap-6">
		<a
			href={SOCIAL_LINKS.linkedin}
			target="_blank"
			rel="noopener noreferrer"
			class="transition-all duration-200 ease-out hover:scale-110 hover:text-neutral-400 focus:outline-2 focus:outline-offset-2 focus:outline-white"
			aria-label="Visit David Fross's LinkedIn profile (opens in new tab)">
			<Icon name="linkedin" size="48" aria-hidden="true" />
		</a>
		<a
			href={`mailto:${SOCIAL_LINKS.email}`}
			class="transition-all duration-200 ease-out hover:scale-110 hover:text-neutral-400 focus:outline-2 focus:outline-offset-2 focus:outline-white"
			aria-label="Send an email to David Fross">
			<Icon name="mailbox" size="48" aria-hidden="true" />
		</a>
	</div>
</MainLayout>
